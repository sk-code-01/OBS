{
  "name": "@clawobs/clickhouse-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./migrations/*": "./migrations/*"
  },
  "scripts": {
    "migrate": "tsx --env-file=../../.env src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@clickhouse/client": "^1.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
