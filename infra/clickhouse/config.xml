<?xml version="1.0"?>
<!--
  Minimal ClickHouse override for local dev.
  Enables async_insert tuning that pairs well with the ingest pipeline.
-->
<clickhouse>
  <async_insert_threads>8</async_insert_threads>
  <async_insert_max_data_size>10485760</async_insert_max_data_size>
  <async_insert_busy_timeout_ms>200</async_insert_busy_timeout_ms>
</clickhouse>
