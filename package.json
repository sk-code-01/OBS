{
  "name": "clawobs",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@clawobs/ingest",
    "build": "turbo run build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "migrate": "pnpm -F @clawobs/clickhouse-schema migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
