# Copy this file to `.env` and fill in your ClickHouse Cloud credentials.
# The ingest service + migration runner both read these values.

# From your ClickHouse Cloud console — looks like:
# https://xxxxxx.region.aws.clickhouse.cloud:8443
CLICKHOUSE_URL=

# Usually "default" unless you created a dedicated user.
CLICKHOUSE_USER=default

CLICKHOUSE_PASSWORD=

# The logical database name. The migration runner creates it if missing.
CLICKHOUSE_DB=clawobs

# Ingest service port.
PORT=4317
LOG_LEVEL=info
